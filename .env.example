# Local development only. Use a secret manager in production.
EGRYSA_CONFIG=config/egrysa.example.json
EGRYSA_INBOUND_KEYS=example-workload=replace-with-a-long-random-client-key
EGRYSA_RECEIPT_FINGERPRINT_KEY=replace-with-at-least-32-random-bytes
EGRYSA_RECEIPT_ED25519_PRIVATE_KEY=replace-with-base64-pkcs8-private-key
EGRYSA_RECEIPT_ED25519_PUBLIC_KEY=replace-with-base64-spki-public-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
